{

  "description": "Reúne algumas ferramentas para melhorar a experiencia do usuario nos sitemas Sigaa",
  "manifest_version": 3,
  "name": "SIGAA Ferramentas de Utilidade",
  "version": "1.0",
  "homepage_url": "https://github.com/IanfvBR/SIGAA-ferramentas-de-utilidade",
  "icons": {
      "16": "./icons/icon16.png",
      "32": "./icons/icon32.png",
      "48": "./icons/icon48.png",
      "64": "./icons/icon64.png",
      "96": "./icons/icon96.png",
      "128": "./icons/icon128.png"
    },
  
  "action": {
  "default_icon": "icons/icon32.png",
  "default_title": "Clique para executar, clique novamente para parar."
},

  "browser_specific_settings": {
    "gecko": {
      "id": "IanfvBR@github.com",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "permissions": [
    "scripting",
    "activeTab"
],

    "background": {
        "scripts": ["./scripts/background-script.js"]
    }
}