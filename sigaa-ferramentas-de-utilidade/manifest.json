{

  "description": "Reúne algumas ferramentas para melhor a experiencia do usuario nos sitemas Sigaa",
  "manifest_version": 3,
  "name": "SIGAA Ferramentas de Utilidade",
  "version": "1.0",
  "homepage_url": "https://github.com/IanfvBR/SIGAA-sinalizador-de-conflitos",
  "icons": {
      "16": "./icons/icon16.png",
      "32": "./icons/icon32.png",
      "48": "./icons/icon48.png",
      "64": "./icons/icon64.png",
      "96": "./icons/icon96.png",
      "128": "./icons/icon128.png"
    },

  "browser_specific_settings": {
    "gecko": {
      "id": "IanfvBR@github.com",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "permissions": [
    "scripting"
],

  "content_scripts": [
  {
    "matches": ["<all_urls>"],
    "js": ["./scripts/calcula-horas-estagio.js", "./scripts/sinaliza-conflitos-horario.js"],
    "run_at": "document_idle"
  }
]
}